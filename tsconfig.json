{
"compilerOptions": {
    "target": "ES2017",
    "lib": ["ES2018", "DOM"],
    "strict": true,
    "noImplicitAny": true,
    "isolatedModules": false,
    "skipLibCheck": true,
    "removeComments": false,
    "declaration": false,
    "sourceMap": false,
    "outDir": "."
  },
  "include": ["Safetyfilter.ts"],
  "exclude": ["node_modules", "tests"]
}
